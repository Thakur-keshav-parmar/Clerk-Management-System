# ─────────────────────────────────────────────────────────────
# EduNova — AWS Production Environment
# Copy this to .env and fill in your real values
# ─────────────────────────────────────────────────────────────

# Storage backend: "aws" uses DynamoDB, "local" uses db.json
STORAGE=aws

# DynamoDB
AWS_REGION=ap-south-1
DYNAMO_TABLE=clerk_app

# JWT — CHANGE THIS to a long random string before going live
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# CORS — set to your EC2 public IP or domain (e.g. http://13.234.x.x:8000)
ALLOWED_ORIGIN=*

# Razorpay (optional — for online payments)
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Twilio WhatsApp OTP (optional)
TWILIO_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
